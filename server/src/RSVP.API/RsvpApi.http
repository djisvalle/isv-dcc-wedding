@RSVP_HostAddress = https://localhost:7211

POST {{RSVP_HostAddress}}/api/auth
Content-Type: application/json
Accept: application/json
{
    "username": "admin",
    "password": "admin"
}

###

POST {{RSVP_HostAddress}}/api/user
Content-Type: application/json
Accept: application/json
{
  "username": "admin",
  "password": "admin",
  "role": "admin"
}

###

GET {{RSVP_HostAddress}}/api/user
Content-Type: application/json
Authorization: Bearer {{@BearerToken}}
Accept: application/json

###

POST {{RSVP_HostAddress}}/api/guest
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{@BearerToken}}
{
  "fullname": "Test2 Test2"
}

